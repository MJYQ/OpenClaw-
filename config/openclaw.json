{
  "project_name": "OpenClaw-Recruitment-Agent",

  "description": "基于OpenClaw多Agent架构的智能招聘办公助手",

  "gateway": {
    "enabled": true,
    "mode": "local"
  },

  "agents": [
    {
      "name": "job_agent",
      "role": "岗位需求分析Agent",
      "path": "agents/job_agent",
      "skills": [
        "jd_parser"
      ]
    },

    {
      "name": "resume_agent",
      "role": "简历筛选Agent",
      "path": "agents/resume_agent",
      "skills": [
        "resume_parser",
        "match_score"
      ]
    },

    {
      "name": "interview_agent",
      "role": "面试管理Agent",
      "path": "agents/interview_agent",
      "skills": [
        "interview_generator"
      ]
    },

    {
      "name": "report_agent",
      "role": "招聘报告生成Agent",
      "path": "agents/report_agent",
      "skills": [
        "report_generator"
      ]
    }
  ],


  "skills": {
    "path": "skills",
    "enabled": [
      "jd_parser",
      "resume_parser",
      "match_score",
      "interview_generator",
      "report_generator"
    ]
  },


  "storage": {
    "type": "sqlite",
    "database": "data/recruitment.db"
  },


  "security": {
    "file_access": {
      "allow_read": true,
      "allow_write": true
    },

    "network_access": false,

    "privacy_protection": true
  },


  "logging": {
    "level": "info",
    "file": "logs/openclaw.log"
  }
}
